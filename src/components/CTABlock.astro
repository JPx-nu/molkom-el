---
/**
 * CTABlock — full-width dark call-to-action band.
 *
 * Used before the footer on most pages. Features a navy gradient
 * background with subtle radial red/white pattern overlay for depth.
 * White primary button + ghost outline secondary button.
 */
interface Props {
  title: string;
  text?: string;
  primaryCTA: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const { title, text, primaryCTA, secondaryCTA } = Astro.props;
---

<section class="cta-block">
  <div class="container" style="text-align: center; padding: var(--space-4xl) 0;">
    <h2 class="cta-block__title">{title}</h2>
    {text && <p class="cta-block__text">{text}</p>}
    <div class="cta-block__actions">
      <a href={primaryCTA.href} class="btn btn--white">{primaryCTA.label}</a>
      {secondaryCTA && (
        <a href={secondaryCTA.href} class="btn" style="border: 1.5px solid rgba(255,255,255,0.3); color: white;">
          {secondaryCTA.label}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-block {
    background: linear-gradient(135deg, var(--color-ink) 0%, #152d47 50%, #0F2137 100%);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  /* Subtle geometric pattern overlay */
  .cta-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(200, 16, 46, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 50%, rgba(255, 255, 255, 0.03) 0%, transparent 40%);
    pointer-events: none;
  }

  .cta-block__title {
    color: var(--color-white);
    margin-bottom: var(--space-md);
    position: relative;
  }

  .cta-block__text {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.7);
    max-width: 500px;
    margin: 0 auto var(--space-xl);
    position: relative;
  }

  .cta-block__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
  }
</style>
