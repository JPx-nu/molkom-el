---
/**
 * Hero — full-viewport or narrow banner used on every page.
 *
 * Variants:
 *   full  — 100vh with background image, dual CTAs, scroll indicator (homepage)
 *   narrow — compact sub-page banner (40vh)
 *
 * The `dark` flag activates a navy gradient background with light text,
 * used for service sub-pages that lack a hero photo. When combined with
 * an image, it applies a dark overlay instead of the default white-fade.
 *
 * Overlay strategy (full variant with image):
 *   Layer 1: bottom-up dark gradient — darkens CTA area for contrast
 *   Layer 2: left-to-right white fade — keeps left-aligned text readable
 */
import { Image } from 'astro:assets';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  image?: ImageMetadata;
  /** 'full' = 100vh homepage hero, 'narrow' = compact sub-page banner */
  variant?: 'full' | 'narrow';
  /** Navy gradient background with light text for pages without hero photos */
  dark?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCTA,
  secondaryCTA,
  image,
  variant = 'full',
  dark = false,
} = Astro.props;
---

<section class={`hero hero--${variant}${dark ? ' hero--dark' : ''}`}>
  {image && (
    <div class="hero__bg">
      <Image
        src={image}
        alt=""
        widths={[640, 1024, 1440, 1920]}
        sizes="100vw"
        loading="eager"
        class="hero__bg-img"
      />
      <div class="hero__overlay" />
    </div>
  )}

  <div class="hero__content container">
    {eyebrow && <span class="eyebrow hero__eyebrow">{eyebrow}</span>}
    <h1 class="hero__title">{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}

    {(primaryCTA || secondaryCTA) && (
      <div class="hero__actions">
        {primaryCTA && (
          <a href={primaryCTA.href} class="btn btn--primary">{primaryCTA.label}</a>
        )}
        {secondaryCTA && (
          <a href={secondaryCTA.href} class="btn btn--outline">{secondaryCTA.label}</a>
        )}
      </div>
    )}
  </div>

  {variant === 'full' && (
    <div class="hero__scroll-indicator" aria-hidden="true">
      <svg width="20" height="28" viewBox="0 0 20 28" fill="none">
        <rect x="1" y="1" width="18" height="26" rx="9" stroke="currentColor" stroke-width="1.5"/>
        <circle class="hero__scroll-dot" cx="10" cy="8" r="2.5" fill="currentColor"/>
      </svg>
    </div>
  )}
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero--full {
    min-height: 100vh;
    min-height: 100dvh;
    padding-top: var(--header-height);
  }

  .hero--narrow {
    min-height: 40vh;
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-3xl);
    background: var(--color-surface);
  }

  /* Background image */
  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(15, 33, 55, 0.4) 0%,
        rgba(15, 33, 55, 0.1) 30%,
        transparent 50%
      ),
      linear-gradient(
        to right,
        rgba(255, 255, 255, 0.95) 0%,
        rgba(255, 255, 255, 0.85) 30%,
        rgba(255, 255, 255, 0.4) 55%,
        rgba(255, 255, 255, 0) 75%
      );
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 650px;
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-3xl);
  }

  .hero__eyebrow {
    display: block;
    margin-bottom: var(--space-md);
    animation: fadeUp 0.6s ease both;
  }

  .hero__title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
    animation: fadeUp 0.6s ease 0.1s both;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-body);
    max-width: 500px;
    margin-bottom: var(--space-xl);
    animation: fadeUp 0.6s ease 0.2s both;
  }

  .hero--narrow .hero__subtitle {
    color: var(--color-body);
  }

  /* Dark variant for service sub-pages */
  .hero--dark {
    background: linear-gradient(135deg, var(--color-ink) 0%, #1a3554 100%);
  }

  .hero--dark .hero__title {
    color: var(--color-white);
    text-shadow: none;
  }

  .hero--dark .hero__subtitle {
    color: rgba(255, 255, 255, 0.7);
  }

  .hero--dark .hero__eyebrow {
    color: rgba(255, 255, 255, 0.5);
  }

  /* Dark overlay when image + dark are combined */
  .hero--dark .hero__overlay {
    background: linear-gradient(
      135deg,
      rgba(15, 33, 55, 0.85) 0%,
      rgba(26, 53, 84, 0.75) 100%
    );
  }

  .hero--dark::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to right, var(--color-red), transparent);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    animation: fadeUp 0.6s ease 0.3s both;
  }

  /* Glass outline button on full hero */
  .hero--full .btn--outline {
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-color: rgba(255, 255, 255, 0.5);
    color: var(--color-white);
  }
  .hero--full .btn--outline:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: var(--color-white);
    color: var(--color-white);
  }

  /* Scroll indicator */
  .hero__scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    animation: fadeUp 0.6s ease 0.5s both;
  }

  .hero__scroll-dot {
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollBounce {
    0%, 100% { cy: 8; opacity: 1; }
    50% { cy: 18; opacity: 0.3; }
  }

  @media (max-width: 768px) {
    .hero--full {
      min-height: 90vh;
    }
    .hero__overlay {
      background:
        linear-gradient(
          to top,
          rgba(15, 33, 55, 0.4) 0%,
          rgba(15, 33, 55, 0.1) 30%,
          transparent 50%
        ),
        linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.95) 0%,
          rgba(255, 255, 255, 0.8) 50%,
          rgba(255, 255, 255, 0.3) 100%
        );
    }
    .hero__actions {
      flex-direction: column;
    }
    .hero__actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
